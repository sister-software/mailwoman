{
	"name": "@mailwoman/formatter",
	"version": "5.10.1",
	"description": "The inverse of the parser: render Mailwoman `ComponentTag` components into an idiomatic, locale-aware address string — plus a canonical, normalized match key for record linkage. Consolidates the former core/formatter stub and corpus synthesis formatter behind one API.",
	"license": "AGPL-3.0-only OR LicenseRef-Commercial",
	"repository": {
		"type": "git",
		"url": "https://github.com/sister-software/mailwoman.git",
		"directory": "formatter"
	},
	"files": [
		"out/**/*.js",
		"out/**/*.js.map",
		"out/**/*.d.ts",
		"out/**/*.d.ts.map"
	],
	"type": "module",
	"exports": {
		"./package.json": "./package.json",
		".": {
			"node": "./index.ts",
			"default": "./out/index.js",
			"types": "./out/index.d.ts"
		},
		"./format": {
			"node": "./format.ts",
			"default": "./out/format.js",
			"types": "./out/format.d.ts"
		},
		"./key": {
			"node": "./key.ts",
			"default": "./out/key.js",
			"types": "./out/key.d.ts"
		}
	},
	"publishConfig": {
		"exports": {
			"./package.json": "./package.json",
			".": {
				"types": "./out/index.d.ts",
				"default": "./out/index.js"
			},
			"./format": {
				"types": "./out/format.d.ts",
				"default": "./out/format.js"
			},
			"./key": {
				"types": "./out/key.d.ts",
				"default": "./out/key.js"
			}
		},
		"access": "public"
	},
	"dependencies": {
		"@fragaria/address-formatter": "^6.7.1",
		"@mailwoman/core": "workspace:*"
	},
	"devDependencies": {
		"@types/node": ">=26.1.1"
	}
}
