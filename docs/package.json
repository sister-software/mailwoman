{
	"name": "@mailwoman/docs",
	"version": "0.0.0",
	"private": true,
	"description": "Docusaurus knowledge base for Mailwoman Geocoder",
	"imports": {
		"#e2e": "./test/e2e/index.ts",
		"#e2e/*": "./test/e2e/*"
	},
	"exports": {
		"./components/*": "./src/components/*.tsx",
		"./contexts/*": "./src/contexts/*.tsx"
	},
	"scripts": {
		"build": "docusaurus build",
		"build-storybook": "storybook build",
		"clear": "docusaurus clear",
