{
	"name": "@mailwoman/nominatim",
	"version": "5.0.0",
	"description": "Nominatim drop-in — a Nominatim-compatible HTTP geocoding API (search / reverse / lookup / status) over the Mailwoman engine. Run it with `npx @mailwoman/nominatim serve`.",
	"license": "AGPL-3.0-only",
	"repository": {
		"type": "git",
		"url": "https://github.com/sister-software/mailwoman.git",
		"directory": "nominatim"
	},
	"bin": "./out/cli.js",
	"files": [
		"out/**/*.js",
		"out/**/*.js.map",
		"out/**/*.d.ts",
		"out/**/*.d.ts.map",
		"README.md"
	],
	"type": "module",
	"exports": {
		"./package.json": "./package.json",
		".": "./out/index.js"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@mailwoman/annotations": "workspace:*",
		"@mailwoman/codex": "workspace:*",
		"@mailwoman/neural": "workspace:*",
		"@mailwoman/nuts-lookup": "workspace:*",
		"@mailwoman/resolver": "workspace:*",
		"@mailwoman/resolver-wof-sqlite": "workspace:*",
		"@mailwoman/spatial": "workspace:*",
		"@mailwoman/timezone-lookup": "workspace:*",
		"@mailwoman/un-locode-lookup": "workspace:*",
		"express": "^5.2.1",
		"mailwoman": "workspace:*"
	}
}
