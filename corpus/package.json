{
	"name": "@mailwoman/corpus",
	"version": "7.6.0",
	"description": "Mailwoman corpus pipeline: BIO-labeled dataset builder for the neural classifier.",
	"license": "AGPL-3.0-only OR LicenseRef-Commercial",
	"repository": {
		"type": "git",
		"url": "https://github.com/sister-software/mailwoman.git",
		"directory": "corpus"
	},
	"files": [
		"out/**/*.js",
		"out/**/*.js.map",
		"out/**/*.d.ts",
		"out/**/*.d.ts.map",
		"*.ts",
		"*.tsx",
		"**/*.ts",
		"**/*.tsx",
		"!*.test.ts",
		"!*.test.tsx",
		"!**/*.test.ts",
		"!**/*.test.tsx"
	],
	"type": "module",
	"exports": {
		"./package.json": "./package.json",
		".": {
			"node": "./src/index.ts",
			"default": "./out/src/index.js",
			"types": "./out/src/index.d.ts"
		},
		"./types": {
			"node": "./src/types.ts",
			"default": "./out/src/types.js",
			"types": "./out/src/types.d.ts"
		},
		"./format": {
			"node": "./src/format.ts",
			"default": "./out/src/format.js",
			"types": "./out/src/format.d.ts"
		},
		"./license": {
			"node": "./src/license.ts",
			"default": "./out/src/license.js",
			"types": "./out/src/license.d.ts"
		},
		"./build": {
			"node": "./src/build.ts",
			"default": "./out/src/build.js",
			"types": "./out/src/build.d.ts"
		},
		"./adapters": {
			"node": "./src/adapters/index.ts",
			"default": "./out/src/adapters/index.js",
			"types": "./out/src/adapters/index.d.ts"
		},
		"./tools": {
			"node": "./src/tools/index.ts",
			"default": "./out/src/tools/index.js",
			"types": "./out/src/tools/index.d.ts"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@dsnp/parquetjs": "1.8.8",
		"@mailwoman/ban": "workspace:*",
		"@mailwoman/codex": "workspace:*",
		"@mailwoman/core": "workspace:*",
		"@mailwoman/formatter": "workspace:*",
		"csv-parse": "^7.0.1",
		"fast-glob": "^3.3.3",
		"fastest-levenshtein": "^1.0.16",
		"lru-cache": "^11.5.2",
		"spliterator": "^4.0.0"
	},
	"devDependencies": {
		"@types/node": ">=26.1.1"
	}
}
