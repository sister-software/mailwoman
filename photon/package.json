{
	"name": "@mailwoman/photon",
	"version": "7.8.0",
	"description": "Photon drop-in — a Photon-compatible autocomplete/type-ahead geocoding API (GeoJSON FeatureCollection over /api + /reverse) on the Mailwoman engine. Run it with `npx @mailwoman/photon serve`.",
	"license": "AGPL-3.0-only OR LicenseRef-Commercial",
	"repository": {
		"type": "git",
		"url": "https://github.com/sister-software/mailwoman.git",
		"directory": "photon"
	},
	"bin": "./out/cli.js",
	"files": [
		"out/**/*.js",
		"out/**/*.js.map",
		"out/**/*.d.ts",
		"out/**/*.d.ts.map",
		"README.md",
		"*.ts",
		"*.tsx",
		"**/*.ts",
		"**/*.tsx",
		"!*.test.ts",
		"!*.test.tsx",
		"!**/*.test.ts",
		"!**/*.test.tsx"
	],
	"type": "module",
	"exports": {
		"./package.json": "./package.json",
		".": {
			"node": "./index.ts",
			"default": "./out/index.js",
			"types": "./out/index.d.ts"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@hono/zod-openapi": "^1.5.1",
		"@mailwoman/annotations": "workspace:*",
		"@mailwoman/api-kit": "workspace:*",
		"@mailwoman/ban": "workspace:*",
		"@mailwoman/codex": "workspace:*",
		"@mailwoman/neural": "workspace:*",
		"@mailwoman/neural-weights-en-us": "workspace:*",
		"@mailwoman/resolver": "workspace:*",
		"@mailwoman/resolver-wof-sqlite": "workspace:*",
		"hono": "^4.12.31",
		"mailwoman": "workspace:*",
		"zod": "^4.4.3"
	}
}
