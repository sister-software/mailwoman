{
	"name": "@mailwoman/mcp",
	"version": "7.7.0",
	"description": "MCP server — mailwoman's spatial toolset for agents (parse, geocode, poi_search, overpass_export, layer_manifest).",
	"license": "AGPL-3.0-only OR LicenseRef-Commercial",
	"repository": {
		"type": "git",
		"url": "https://github.com/sister-software/mailwoman.git",
		"directory": "mcp"
	},
	"bin": {
		"mailwoman-mcp": "./out/cli.js"
	},
	"files": [
		"out/**/*.js",
		"out/**/*.js.map",
		"out/**/*.d.ts",
		"out/**/*.d.ts.map",
		"README.md",
		"*.ts",
		"*.tsx",
		"**/*.ts",
		"**/*.tsx",
		"!*.test.ts",
		"!*.test.tsx",
		"!**/*.test.ts",
		"!**/*.test.tsx"
	],
	"type": "module",
	"exports": {
		"./package.json": "./package.json",
		".": {
			"node": "./index.ts",
			"default": "./out/index.js",
			"types": "./out/index.d.ts"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@mailwoman/core": "workspace:*",
		"@mailwoman/neural": "workspace:*",
		"@mailwoman/poi-taxonomy": "workspace:*",
		"@mailwoman/resolver": "workspace:*",
		"@mailwoman/resolver-wof-sqlite": "workspace:*",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"mailwoman": "workspace:*",
		"zod": "^4.4.3"
	},
	"peerDependencies": {
		"@mailwoman/resolver-wof-sqlite": "workspace:*"
	},
	"peerDependenciesMeta": {
		"@mailwoman/resolver-wof-sqlite": {
			"optional": true
		}
	}
}
