{
	"name": "@mailwoman/poi-taxonomy",
	"version": "7.8.0",
	"description": "POI category taxonomy + phrase lexicon — Overture category snapshot, infrastructure extension namespace, and the synonym table mapping query phrases ('drinking fountain', 'fiber hut') to category ids.",
	"license": "AGPL-3.0-only OR LicenseRef-Commercial",
	"repository": {
		"type": "git",
		"url": "https://github.com/sister-software/mailwoman.git",
		"directory": "poi-taxonomy"
	},
	"files": [
		"out/**/*.js",
		"out/**/*.js.map",
		"out/**/*.d.ts",
		"out/**/*.d.ts.map",
		"data/**/*.json",
		"*.ts",
		"*.tsx",
		"**/*.ts",
		"**/*.tsx",
		"!*.test.ts",
		"!*.test.tsx",
		"!**/*.test.ts",
		"!**/*.test.tsx"
	],
	"type": "module",
	"exports": {
		"./package.json": "./package.json",
		".": {
			"node": "./index.ts",
			"default": "./out/index.js",
			"types": "./out/index.d.ts"
		},
		"./table": {
			"node": "./table.ts",
			"default": "./out/table.js",
			"types": "./out/table.d.ts"
		},
		"./overpass": {
			"node": "./overpass.ts",
			"default": "./out/overpass.js",
			"types": "./out/overpass.d.ts"
		},
		"./data/*.json": "./data/*.json"
	},
	"publishConfig": {
		"access": "public"
	}
}
