#!/usr/bin/env sh

# Lint-only pre-commit (2026-07-08): tests are CI's job — the Test workflow runs the full suite on
# every push/PR. `yarn lint` = oxlint (incl. the `sister-software/no-process-globals` raw-access
# gate), oxfmt --check, and the python toolchain checks.
#
# set -e: without it a failing `yarn lint` never blocked the commit (the hook's exit code was the
# LAST command's) — the old lint+tests hook had this hole.
set -e

yarn lint

# Raw-angle MDX lint (always-on): a bare `<55` in docs prose is a build-breaking MDX-JSX parse
# error — this class broke three builds on 2026-06-10. See the script header. (Stays a script:
# oxlint lints TS, not .mdx prose.)
node scripts/lint-mdx-angles.ts
