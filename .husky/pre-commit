#!/usr/bin/env sh

# Fast gate on main: lint + unit tests (~10s). The slow integration tests
# (FST serialize, CLI e2e, resolve-flag) run in CI only.
#
# Feature branches skip entirely — CI on the PR is the real check.

branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)"

if [ "$branch" = "main" ]; then
  yarn lint
  yarn ci:test:fast
fi

# Raw-angle MDX lint (always-on): a bare `<55` in docs prose is a build-breaking
# MDX-JSX parse error — this class broke three builds on 2026-06-10. See the script header.
node scripts/lint-mdx-angles.ts
