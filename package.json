{
	"name": "@mailwoman/universe",
	"version": "4.16.2",
	"private": true,
	"description": "Mailwoman monorepo workspace root.",
	"license": "AGPL-3.0-only",
	"contributors": [
		{
			"name": "Teffen Ellis",
			"email": "teffen@sister.software"
		}
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/sister-software/mailwoman.git"
	},
	"workspaces": [
		"mailwoman",
		"annotations",
		"nominatim",
		"photon",
		"libpostal",
		"timezone-lookup",
		"un-locode-lookup",
		"nuts-lookup",
		"core",
		"resolver",
		"spatial",
		"tiger",
		"osm",
		"cartographer",
		"codex",
		"classifiers",
		"corpus",
		"formatter",
		"record",
		"match",
		"registry",
		"address-id",
		"neural",
		"neural-web",
		"neural-weights-en-us",
		"neural-weights-fr-fr",
		"normalize",
		"kind-classifier",
		"locale-gate",
		"variant-aliases",
		"phrase-grouper",
		"query-shape",
		"resolver-wof-sqlite",
		"resolver-wof-wasm",
		"tile-worker",
		"docs"
	],
	"type": "module",
	"scripts": {
		"ci:docs": "run-s compile docs:build",
		"ci:smoke": "node scripts/smoke-clean-install.ts",
		"ci:test": "vitest --run",
		"ci:test:fast": "vitest --run --exclude './mailwoman/test/**' --exclude './resolver-wof-sqlite/fst-serialize.test.ts' --exclude './resolver-wof-sqlite/fst-builder.test.ts' --exclude './resolver-wof-sqlite/fst-autocomplete.test.ts' --exclude './neural-web/web-onnx-runner.test.ts'",
		"ci:tile-worker": "run-s compile",
		"compile": "NODE_OPTIONS=\"--max-old-space-size=3000\" tsc -b",
		"compile:clean": "tsc -b --clean",
		"docs:build": "yarn workspace @mailwoman/docs build",
		"lint": "run-s lint:oxlint lint:oxfmt lint:python",
		"lint:oxlint": "oxlint",
		"lint:oxfmt": "oxfmt --check .",
		"lint:python": "uvx ruff@0.15.20 check corpus-python && uvx ruff@0.15.20 format --check corpus-python",
		"lint:fix": "run-s fix:oxlint format fix:python",
		"fix:oxlint": "oxlint --fix",
		"format": "oxfmt .",
		"fix:python": "uvx ruff@0.15.20 check --fix corpus-python && uvx ruff@0.15.20 format corpus-python",
		"prepare": "husky",
		"release": "release-it",
		"test": "vitest",
		"test:coverage": "vitest --coverage",
		"test:integration": "vitest --dir ./mailwoman/test",
		"test:unit": "vitest --exclude ./mailwoman/test",
		"typecheck:scripts": "tsc -p scripts/tsconfig.json --noEmit"
	},
	"devDependencies": {
		"@duckdb/node-api": "^1.5.3-r.3",
		"@inkjs/ui": "^2.0.0",
		"@release-it-plugins/workspaces": "^5.0.3",
		"@sister.software/oxfmt-config": "^9.1.0",
		"@sister.software/oxlint-config": "^9.1.0",
		"@sister.software/tsconfig": "^8.0.1",
		"@types/express": "^5.0.6",
		"@types/geojson": "^7946.0.16",
		"@types/node": "^26.0.1",
		"@types/pluralize": "^0.0.33",
		"@types/react": "^19.2.17",
		"@types/regenerate": "^1.4.3",
		"ansi_up": "^6.0.6",
		"chalk": "^5.6.2",
		"csv-parse": "^5.6.0",
		"fast-glob": "^3.3.3",
		"faucet": "^0.0.4",
		"husky": "^9.1.7",
		"ink": "^7.0.5",
		"npm-run-all": "^4.1.5",
		"oxfmt": "0.56.0",
		"oxlint": "1.71.0",
		"react": "^19.2.7",
		"release-it": "^19.2.4",
		"spliterator": "^2.2.1",
		"tap-difflet": "^0.7.2",
		"typescript": "^6.0.3",
		"vitest": "3.2.6",
		"zx": "^8.8.5"
	},
	"resolutions": {
		"@dsnp/parquetjs@1.7.0": "patch:@dsnp/parquetjs@npm%3A1.7.0#./.yarn/patches/@dsnp-parquetjs-npm-1.7.0-efe8288b39.patch",
		"undici": "^6.24.0",
		"http-proxy-middleware@^2.0.9": "2.0.10"
	},
	"engines": {
		"node": ">=24.18.0"
	},
	"packageManager": "yarn@4.14.1+sha512.64df448055b2d37ba269d7db535a469b8da93f8ef1140c25fd7a83c00a8fbaacb214ca0e02553b92a2c54cef78bb67d0b4817fab02001df0e24fac0faccc3b42"
}
