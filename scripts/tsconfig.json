{
	// Leaf type-check project for the toolshed. Not part of the build graph
	// (composite:false, noEmit) — invoked explicitly via `tsc -p scripts/tsconfig.json`
	// (and in CI) so `scripts/` stops being the one untyped corner where rot
	// accumulates. Scoped to .ts/.tsx; the loose .mjs helpers are not checked.
	"extends": "@sister.software/tsconfig",
	"compilerOptions": {
		"noEmit": true,
		"emitDeclarationOnly": false,
		"declaration": false,
		"declarationMap": false,
		"sourceMap": false,
		"composite": false,
		"incremental": false,
		"checkJs": false,
		"allowJs": false,
		"rootDir": ".."
	},
	"include": ["./**/*.ts", "./**/*.tsx"],
	// `diagnostic/` is the throwaway-diagnostic namespace (.gitignore'd);
	// excluding it keeps `yarn typecheck:scripts` clean against local scratch as well as in CI.
	// `demo-cascade-smoke.ts` imports the docs-app browser source (`docs/src/shared/*`) by relative
	// path; under this node module config TS mis-detects those ESM files as CommonJS (TS1287). It's a
	// runtime smoke test (exercised by promotion-gate). Follow-up: extract the shared cascade logic
	// into a package so both the demo and the smoke test import it across a clean boundary.
	"exclude": ["./**/out/**", "./**/node_modules/**", "./diagnostic/**", "./eval/demo-cascade-smoke.ts"]
}
