{
	"name": "@mailwoman/core",
	"version": "7.5.0",
	"description": "Mailwoman core: tokenization, decoder, formatter, resources, filters, utils.",
	"license": "AGPL-3.0-only OR LicenseRef-Commercial",
	"repository": {
		"type": "git",
		"url": "https://github.com/sister-software/mailwoman.git",
		"directory": "core"
	},
	"files": [
		"out/**/*.js",
		"out/**/*.js.map",
		"out/**/*.d.ts",
		"out/**/*.d.ts.map",
		"data/**/*",
		"THIRD_PARTY_NOTICES.md",
		"*.ts",
		"*.tsx",
		"**/*.ts",
		"**/*.tsx",
		"!*.test.ts",
		"!*.test.tsx",
		"!**/*.test.ts",
		"!**/*.test.tsx"
	],
	"type": "module",
	"exports": {
		"./package.json": "./package.json",
		".": {
			"node": "./index.ts",
			"default": "./out/index.js",
			"types": "./out/index.d.ts"
		},
		"./coarse-placer": {
			"node": "./coarse-placer/coarse-placer.ts",
			"default": "./out/coarse-placer/coarse-placer.js",
			"types": "./out/coarse-placer/coarse-placer.d.ts"
		},
		"./coarse-placer/tools": {
			"node": "./coarse-placer/tools/index.ts",
			"default": "./out/coarse-placer/tools/index.js",
			"types": "./out/coarse-placer/tools/index.d.ts"
		},
		"./tokenization": {
			"node": "./tokenization/index.ts",
			"default": "./out/tokenization/index.js",
			"types": "./out/tokenization/index.d.ts"
		},
