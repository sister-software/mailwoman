			"node": "./kysley/dialect-config.ts",
			"default": "./out/kysley/dialect-config.js",
			"types": "./out/kysley/dialect-config.d.ts"
		},
		"./errors": {
			"node": "./errors/index.ts",
			"default": "./out/errors/index.js",
			"types": "./out/errors/index.d.ts"
		},
		"./routing": {
			"node": "./routing/index.ts",
			"default": "./out/routing/index.js",
			"types": "./out/routing/index.d.ts"
		},
		"./filters/*": {
			"node": "./filters/*.ts",
			"default": "./out/filters/*.js",
			"types": "./out/filters/*.d.ts"
		},
		"./tools": {
			"node": "./tools/index.ts",
			"default": "./out/tools/index.js",
			"types": "./out/tools/index.d.ts"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"async-init": "^1.0.0",
		"axios": "^1.18.1",
		"axios-cache-interceptor": "^1.12.0",
		"change-case": "^5.4.4",
		"d3-color": "^3.1.0",
		"d3-scale-chromatic": "^3.1.0",
		"fast-glob": "^3.3.3",
		"http-status-codes": "^2.3.0",
		"json-colorizer": "^3.0.1",
		"kysely": "^0.29.4",
		"path-ts": "^2.1.0",
		"pino": "^10.3.1",
