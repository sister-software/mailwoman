{
	"extends": "@sister.software/tsconfig",
	"watchOptions": {
		"excludeDirectories": [
			"**/.git",
			"**/.yarn",
			"**/.vscode",
			"**/.vscode-test-web",
			"**/dist",
			"**/out",
			"**/.drafts",
			"**/.github",
			"**/node_modules"
		]
	},
	"compilerOptions": {
		"baseUrl": ".",
		"outDir": "./out"
	},
	"include": [
		"index.ts",
		"cli.ts",
		"vitest.config.ts",
		"eslint.config.mjs",
		"sdk/**/*",
		"server/**/*",
		"scripts/**/*",
		"test/**/*",
		"utils/**/*",
		"commands/**/*"
	],
	"exclude": ["./out/**/*", "./packages/**/*"],
	"references": [{ "path": "./packages/core" }, { "path": "./packages/classifiers" }, { "path": "./packages/corpus" }]
}
