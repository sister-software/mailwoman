{
	"name": "@mailwoman/classifiers",
	"version": "5.1.0",
	"description": "Mailwoman rule-based classifiers.",
	"license": "AGPL-3.0-only",
	"repository": {
		"type": "git",
		"url": "https://github.com/sister-software/mailwoman.git",
		"directory": "classifiers"
	},
	"files": [
		"out/**/*.js",
		"out/**/*.js.map",
		"out/**/*.d.ts",
		"out/**/*.d.ts.map"
	],
	"type": "module",
	"exports": {
		"./package.json": "./package.json",
		".": "./out/index.js",
		"./*": "./out/*"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@mailwoman/core": "workspace:*"
	}
}
