{
	"name": "mailwoman",
	"version": "2.1.0",
	"description": "Utilities for working with contacts for email, phone, and postal addresses.",
	"license": "AGPL-3.0-only",
	"contributors": [
		{
			"name": "Teffen Ellis",
			"email": "teffen@sister.software"
		},
		{
			"name": "Pelias Contributors"
		}
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/sister-software/mailwoman.git",
		"directory": "mailwoman"
	},
	"bugs": {
		"url": "https://github.com/sister-software/mailwoman/issues"
	},
	"homepage": "https://github.com/sister-software/mailwoman",
	"type": "module",
	"exports": {
		"./package.json": "./package.json",
		".": "./out/index.js",
		"./server": "./out/server/index.js",
		"./sdk/test": "./out/sdk/test/index.js",
		"./sdk/repo": "./out/sdk/repo.js",
		"./sdk/cli": "./out/sdk/cli.js"
	},
	"dependencies": {
		"@fragaria/address-formatter": "^6.3.0",
		"@inkjs/ui": "^2.0.0",
		"@mailwoman/classifiers": "workspace:*",
		"@mailwoman/core": "workspace:*",
		"change-case": "^5.4.4",
		"core-js": "^3.49.0",
		"express": "^5.0.1",
		"geojson": "^0.5.0",
		"ink": "^7.0.3",
		"ioredis": "^5.4.1",
		"pastel": "^4.0.1",
		"path-ts": "^1.0.5",
		"piscina": "^4.7.0",
		"pluralize": "^8.0.0",
		"react": "^19.2.6",
		"regenerate": "^1.4.2",
		"spliterator": "^2.0.0",
		"zod": "^4.1.12"
	},
	"files": [
		"!out/test/**/*",
		"!**/*.ts",
		"out/**/*.js",
		"out/**/*.js.map",
		"out/**/*.d.ts",
		"out/**/*.d.ts.map",
		"out/**/*.json"
	],
	"keywords": [
		"address",
		"parser",
		"usps",
		"postal",
		"pelias"
	],
	"bin": "./out/cli.js",
	"peerDependenciesMeta": {
		"@inkjs/ui": {
			"optional": true
		},
		"core-js": {
			"optional": true
		},
		"ink": {
			"optional": true
		},
		"react": {
			"optional": true
		}
	},
	"publishConfig": {
		"access": "public"
	}
