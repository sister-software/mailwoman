		"@mailwoman/tiger": "workspace:*"
	},
	"files": [
		"!out/test/**/*",
		"!**/*.ts",
		"out/**/*.js",
		"out/**/*.mjs",
		"out/**/*.js.map",
		"out/**/*.mjs.map",
		"out/**/*.d.ts",
		"out/**/*.d.ts.map",
		"out/**/*.json"
	],
	"keywords": [
		"address",
		"parser",
		"usps",
		"postal",
		"pelias"
	],
	"bin": "./out/cli.js",
	"peerDependenciesMeta": {
		"@duckdb/node-api": {
			"optional": true
		},
		"@inkjs/ui": {
			"optional": true
		},
		"@mailwoman/resolver-wof-sqlite": {
			"optional": true
		},
		"ink": {
			"optional": true
		},
		"react": {
			"optional": true
		}
	},
	"publishConfig": {
		"access": "public"
	}
