{
	"name": "mailwoman",
	"version": "7.2.0",
	"description": "A calibrated, retrieval-augmented postal-address parser — CLI + library.",
	"keywords": [
		"address",
		"parser",
		"pelias",
		"postal",
		"usps"
	],
	"homepage": "https://github.com/sister-software/mailwoman",
	"bugs": {
		"url": "https://github.com/sister-software/mailwoman/issues"
	},
	"license": "AGPL-3.0-only OR LicenseRef-Commercial",
	"contributors": [
		{
			"name": "Teffen Ellis",
			"email": "teffen@sister.software"
		},
		{
			"name": "Pelias Contributors"
		}
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/sister-software/mailwoman.git",
		"directory": "mailwoman"
	},
	"bin": "./out/cli.js",
	"files": [
		"!out/test/**/*",
		"out/**/*.js",
		"out/**/*.mjs",
		"out/**/*.js.map",
		"out/**/*.mjs.map",
		"out/**/*.d.ts",
		"out/**/*.d.ts.map",
		"out/**/*.json"
	],
	"type": "module",
	"exports": {
		"./package.json": "./package.json",
		".": {
			"node": "./index.ts",
			"default": "./out/index.js",
			"types": "./out/index.d.ts"
		},
		"./geocode-core": {
			"node": "./geocode-core.ts",
			"default": "./out/geocode-core.js",
			"types": "./out/geocode-core.d.ts"
		},
		"./geocode-stream": {
			"node": "./geocode-stream.ts",
			"default": "./out/geocode-stream.js",
			"types": "./out/geocode-stream.d.ts"
		},
		"./resolver-backend": {
			"node": "./resolver-backend.ts",
			"default": "./out/resolver-backend.js",
			"types": "./out/resolver-backend.d.ts"
		},
		"./gazetteer-pipeline": {
			"node": "./gazetteer-pipeline/index.ts",
			"default": "./out/gazetteer-pipeline/index.js",
			"types": "./out/gazetteer-pipeline/index.d.ts"
		},
		"./gazetteer-pipeline/*": {
			"node": "./gazetteer-pipeline/*.ts",
			"default": "./out/gazetteer-pipeline/*.js",
			"types": "./out/gazetteer-pipeline/*.d.ts"
		},
		"./cli-kit": {
			"node": "./cli-kit/index.ts",
			"default": "./out/cli-kit/index.js",
			"types": "./out/cli-kit/index.d.ts"
		},
		"./test-kit": {
			"node": "./test-kit/index.ts",
			"default": "./out/test-kit/index.js",
			"types": "./out/test-kit/index.d.ts"
		},
		"./poi-overpass": {
			"node": "./poi-overpass.ts",
			"default": "./out/poi-overpass.js",
			"types": "./out/poi-overpass.d.ts"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@inkjs/ui": "^2.0.0",
		"@mailwoman/annotations": "workspace:*",
		"@mailwoman/api": "workspace:*",
		"@mailwoman/api-kit": "workspace:*",
		"@mailwoman/ban": "workspace:*",
		"@mailwoman/codex": "workspace:*",
		"@mailwoman/core": "workspace:*",
		"@mailwoman/corpus": "workspace:*",
		"@mailwoman/formatter": "workspace:*",
		"@mailwoman/kind-classifier": "workspace:*",
		"@mailwoman/locale-gate": "workspace:*",
		"@mailwoman/neural": "workspace:*",
		"@mailwoman/normalize": "workspace:*",
		"@mailwoman/phrase-grouper": "workspace:*",
		"@mailwoman/poi-taxonomy": "workspace:*",
		"@mailwoman/query-shape": "workspace:*",
		"@mailwoman/registry": "workspace:*",
		"@mailwoman/resolver": "workspace:*",
		"@mailwoman/resolver-wof-sqlite": "workspace:*",
		"@mailwoman/spatial": "workspace:*",
		"chalk": "^5.6.2",
		"change-case": "^5.4.4",
		"d3-scale-chromatic": "^3.1.0",
		"fast-glob": "^3.3.3",
		"geojson": "^0.5.0",
		"h3-js": "^4.5.0",
		"ink": "^7.0.5",
		"ioredis": "^5.11.1",
		"pastel": "^4.0.1",
		"path-ts": "^2.1.0",
		"piscina": "^5.2.0",
		"pluralize": "^8.0.0",
		"react": "^19.2.7",
		"regenerate": "^1.4.2",
		"spliterator": "^4.0.0",
		"zod": "^4.4.3",
		"zx": "^8.8.5"
	},
	"devDependencies": {
		"@mailwoman/osm": "workspace:*"
	},
	"peerDependencies": {
		"@duckdb/node-api": "1.5.3-r.3",
		"@mailwoman/resolver-wof-sqlite": "workspace:*"
	},
	"peerDependenciesMeta": {
		"@duckdb/node-api": {
			"optional": true
		},
		"@inkjs/ui": {
			"optional": true
		},
		"@mailwoman/resolver-wof-sqlite": {
			"optional": true
		},
		"ink": {
			"optional": true
		},
		"react": {
			"optional": true
		}
	},
	"optionalDependencies": {
		"@mailwoman/tiger": "workspace:*"
	},
	"engines": {
		"node": ">=24.18.0"
	}
}
