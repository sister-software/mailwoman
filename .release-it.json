{
	"$schema": "https://unpkg.com/release-it/schema/release-it.json",
	"plugins": {
		"@release-it-plugins/workspaces": {
			"workspaces": [
				"core",
				"normalize",
				"query-shape",
				"kind-classifier",
				"locale-gate",
				"phrase-grouper",
				"codex",
				"classifiers",
				"corpus",
				"neural",
				"neural-weights-en-us",
				"neural-weights-fr-fr",
				"mailwoman"
			],
			"publish": true,
			"publishCommand": "node scripts/publish-workspace.mjs",
			"skipChecks": true
		}
	},
	"npm": false,
	"git": {
		"commitMessage": "release: v${version}",
		"tagName": "v${version}",
		"tagAnnotation": "Release v${version}",
		"requireCleanWorkingDir": true,
		"requireBranch": "main"
	},
	"github": {
		"release": true,
		"releaseName": "v${version}",
		"releaseNotes": "git log --pretty=format:'* %s (%h)' ${latestTag}...HEAD --no-merges"
	},
	"hooks": {
		"before:init": [
			"echo 'Pre-flight: compile + copy-weights (tests skipped — PR CI already validated)'",
			"yarn compile",
			"node scripts/copy-weights.mjs"
		],
		"after:bump": "yarn prettier --write --log-level warn -u package.json '**/package.json'",
		"after:release": "echo 'Released v${version}'"
	}
}
