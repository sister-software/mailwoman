# Storybook production build output (@mailwoman/react `build-storybook`)
storybook-static

# `mailwoman clients generate` output (mailwoman/tools/generate-clients.ts) — the emitted specs +
# the assembled/verified Python package and Rust crate. One-directional build product, never
# committed; the gated CI job (publish.yml) regenerates it fresh on every dispatch.
/clients-build/

# Yarn (without zero-installs)
# https://yarnpkg.com/getting-started/qa
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Coverage (vitest/istanbul report dirs). The bare rule matches any dir named `coverage` at any depth,
# which also swallows SOURCE dirs that legitimately carry the name — the `mailwoman coverage` CLI command
# and the cartographer `coverage` (fog-of-war) style module. Re-include those (source, not report output).
coverage
!/mailwoman/commands/coverage/
!/mailwoman/commands/coverage/**
!/cartographer/coverage/
!/cartographer/coverage/**
!/docs/articles/evals/coverage/
!/docs/articles/evals/coverage/**
playwright-report
playwright-traces
test-results
*.lcov
.vitest-attachments
__screenshots__


# Python artifacts (packages/corpus-python)
**/.venv/
**/__pycache__/
**/*.egg-info/
**/*.pyc

# Neural-weights model binaries — kept out of git per Phase 2 §"Eval reports committed
# to git (numbers, not models)". model-card.json carries the eval numbers; .onnx and
# .model files are reproduced by `python -m mailwoman_train package`.
packages/neural-weights-*/model.onnx
packages/neural-weights-*/tokenizer.model

# Docs static binaries — large build artifacts (ONNX model, WOF DB, FST gazetteer)
# staged by the demo-assets plugin at build time. Not committed.
docs/static/mailwoman/*.onnx
docs/static/mailwoman/*.model
docs/static/mailwoman/*.db
docs/static/mailwoman/*.bin
docs/static/mailwoman/*.json
docs/static/mailwoman/sqljs/
docs/static/mailwoman/pair-index/

.claude/settings.local.json
CLAUDE.local.md
.claude/scheduled_tasks.lock
.claude/scheduled_tasks.json
.claude/settings.local.json
.claude/worktrees

# expand-golden.ts outputs — operator skims locally, then promotes to versioned dir
data/eval/golden/candidates/

# Calibration confidences (#59): derivable from calibration-set.jsonl + the model, 3 MB. The frozen
# calibration-set.jsonl + the fitted isotonic table ARE committed; the per-span dump is not.
data/eval/calibration/confidences.jsonl

# Local env files (R2 credentials, etc.) — keep out of git
.env
.env.*

corpus-python/.pytest_cache/
output/
# Per-run training-output download dirs (e.g. output-v150-fr-order-s42/ — pulled from the Modal
# volume to local during a re-gate; each holds a ~113MB model.onnx). The exact `output/` above
# only matches the bare dir; the suffixed per-run dirs need their own glob.
output-*/

# Pi session state (not project config)
.pi/flow.json

# Night-shift ephemera — operational plans, logs, and session notes produced during
# autonomous overnight shifts. AI-agent scratch, not project source (#379).
# ds-*.txt / session-notes-*.md were previously only ignored inside
# .agents/skills/deepseek-consult/ (below); the global patterns catch the same
# scratch when it lands at the repo root or elsewhere. No tracked file matches either.
*-NIGHT-SHIFT-*.md
*-NIGHT-SHIFT-*.log
*-NIGHT-SHIFT-*.sh
*-SESSION-HANDOFF.md
HANDOFF-*.md
*-SESSION-RECAP.md
*-DEEP-DIVE-REVIEW.md
ds-*.txt
session-notes-*.md

# DeepSeek consult skill directory — the skill definition (SKILL.md) IS tracked;
# all other files (conversation transcripts, session notes, plans) are AI-agent
# scratch and not project source (#379).
.agents/skills/deepseek-consult/*

# Diagnostic scripts — one-off investigation scripts that aren't part of the shipped
# toolchain. Keepers cited by docs/memories stay tracked; this only hides untracked
# new diag scripts (#379). The scripts live under scripts/diagnostic/ (and one-off
# residual probes under scripts/eval/); the old scripts/diag-*.ts glob never matched.
scripts/diag-*.ts
scripts/diag-*.sh
scripts/diagnostic/
scripts/eval/*-residual.ts

# Coarse-placer (#244) training data + model artifacts — regenerable, not committed
data/coarse-placer/

nightshift

## Conventions

### Never commit shell scripts. Use a `.ts` or `.tsx` file instead.
.sh
