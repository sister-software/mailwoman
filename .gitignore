# Neural-weights model binaries — kept out of git per Phase 2 §"Eval reports committed
# to git (numbers, not models)". model-card.json carries the eval numbers; .onnx and
# .model files are reproduced by `python -m mailwoman_train package`.
packages/neural-weights-*/model.onnx
packages/neural-weights-*/tokenizer.model

# Docs static binaries — large build artifacts (ONNX model, WOF DB, FST gazetteer)
# staged by the demo-assets plugin at build time. Not committed.
docs/static/mailwoman/*.onnx
docs/static/mailwoman/*.model
docs/static/mailwoman/*.db
docs/static/mailwoman/*.bin
docs/static/mailwoman/*.json
docs/static/mailwoman/sqljs/

